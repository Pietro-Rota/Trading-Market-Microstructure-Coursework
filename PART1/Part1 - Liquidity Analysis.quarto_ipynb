    "#| output: asis\n",
    "#| tbl-cap: Descriptive statistics for Spread, Returns, Depth and Volume\n",
    "metrics = {\"Spread_bps\": \"Spread (bps)\", \"Ret_bps\": \"Return (bps)\", \"Depth\": \"Depth (£)\", \"Volume\": \"Volume (£)\"}\n",
    "calcs = [\"mean\", \"std\", \"min\", \"max\"]\n",
    "\n",
    "summary_table = (\n",
    "    df.groupby(\"Stock\")[list(metrics)]\n",
    "    .agg(calcs)\n",
    "    .round(2)\n",
    ")\n",
    "# columns are (metric, stat); stack the metric into rows to narrow it\n",
    "summary_table = summary_table.stack(level=0).rename_axis([\"Stock\", \"Metric\"])\n",
    "summary_table.columns = [c.capitalize() for c in summary_table.columns]\n",
    "summary_table\n",
    "\n",
    "# summary = df.groupby(\"Stock\")[\"Ret_bps\"].agg([\"mean\", \"std\", \"min\", \"max\"])\n",
    "# summary[\"sharpe\"] = (summary[\"mean\"] / summary[\"std\"] * (PERIODS_PER_YEAR ** 0.5)).round(3)\n",
    "# summary.round(2).T   # stats as rows, 3 stock columns\n",
    "\n",
    "flat = summary_table.reset_index()\n",
    "# blank out repeated Stock labels so it still reads as grouped\n",
    "flat[\"Stock\"] = flat[\"Stock\"].mask(flat[\"Stock\"].duplicated(), \"\")\n",
    "flat.to_markdown(index=False)\n",
    "print(flat.to_markdown(index=False))"
   ]
