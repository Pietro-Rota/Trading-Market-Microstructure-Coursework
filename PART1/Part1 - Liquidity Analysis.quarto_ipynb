    "import statsmodels.api as sm\n",
    "from scipy import stats\n",
    "from datetime import time\n",
    "import ptitprince as pt\n",
    "\n",
    "\n",
    "sns.set_style(\"whitegrid\")\n",
    "plt.rcParams.update({\"figure.dpi\": 300, \"axes.titlesize\": 12})\n",
    "\n",
    "# the three chosen stocks, ordered large -> mid -> small cap\n",
    "chosen_stocks = [\"AZN.L\", \"NXT.L\", \"BRBY.L\"]\n",
    "\n",
    "COLOURS = {\"AZN.L\": \"#007D8A\", \"NXT.L\": \"#2A2A2A\", \"BRBY.L\": \"#C5B396\"}  \n",
    "\n",
    "STOCK_INFO = {\n",
    "    \"AZN.L\":  dict(name=\"AstraZeneca plc\",    cap=\"Large-cap\", sector=\"Pharmaceuticals\"),\n",
    "    \"NXT.L\":  dict(name=\"Next plc\",           cap=\"Mid-cap\",   sector=\"Retail / Clothing\"),\n",
    "    \"BRBY.L\": dict(name=\"Burberry Group plc\", cap=\"Small-cap\", sector=\"Luxury / Fashion\"),\n",
    "}\n",
    "\n",
    "# df = pd.read_csv(r\"C:\\Users\\User\\Desktop\\SMM921_trading_data_2026.csv\")\n",
    "df = pd.read_csv(\"SMM921_trading_data_2026.csv\")\n",
    "\n",
    "df = df[df[\"Stock\"].isin(chosen_stocks)].copy()\n",
    "df[\"Date and time\"] = pd.to_datetime(df[\"Date and time\"])\n",
    "df[\"Date\"] = df[\"Date and time\"].dt.date\n",
    "\n",
    "# count crossed/locked quotes (ask <= bid) across ALL hours, before any filtering\n",
    "crossed_all = int(((df[\"Ask\"] - df[\"Bid\"]) / ((df[\"Bid\"] + df[\"Ask\"]) / 2) <= 0).sum())"
   ]
