    "def plot_violin_boxplot(y, title=None, log=False, ax=None):\n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots(figsize=(7, 5))\n",
    "    order = ['AZN.L', 'NXT.L', 'BRBY.L']\n",
    "\n",
    "    pt.half_violinplot(\n",
    "        x=\"Stock\", y=y, data=df, order=order,\n",
    "        hue=\"Stock\", palette=COLOURS,\n",
    "        bw=.2, cut=0, scale=\"area\", inner=None, orient=\"v\", ax=ax,\n",
    "    )\n",
    "    sns.boxplot(\n",
    "        data=df, x=\"Stock\", y=y, order=order,\n",
    "        hue=\"Stock\", palette=COLOURS, legend=False,\n",
    "        width=0.18, showcaps=True,\n",
    "        flierprops=dict(marker='o', markerfacecolor='black', markersize=2, linestyle='none'),\n",
    "        ax=ax,\n",
    "    )\n",
    "    if log:\n",
    "        ax.set_yscale(\"log\")\n",
    "    ax.set_title(title or y.replace('_', ' '))\n",
    "    ax.set_xlabel(\"\")\n",
    "    if ax.get_legend() is not None:\n",
    "        ax.get_legend().remove()\n",
    "\n",
    "\n",
    "# Plot all three liquidity metrics together so the contrast across stocks is obvious.\n",
    "#| fig-cap: \"Liquidity and Volatility Distributions. From Left to Right; Quoted Spread, Depth at Best, and 1-Minute Returns.\"\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "plot_violin_boxplot(\"Spread_bps\",  title=\"Quoted spread (bps) - lower is cheaper\",  ax=axes[0])\n",
    "plot_violin_boxplot(\"Depth\",       title=\"Depth at best (GBP, log) - higher is deeper\", log=True, ax=axes[1])\n",
    "df[\"AbsRet_bps\"] = df[\"Ret_bps\"].abs()\n",
    "plot_violin_boxplot(\"AbsRet_bps\",  title=\"|1-minute return| (bps) - higher is more volatile\", ax=axes[2])\n",
    "axes[0].set_ylabel(\"Basis points\")\n",
    "axes[1].set_ylabel(\"GBP (log scale)\")\n",
    "axes[2].set_ylabel(\"Basis points\")\n",
    "fig.suptitle(\"Liquidity and volatility distributions across the three stocks\", fontweight=\"bold\")\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
