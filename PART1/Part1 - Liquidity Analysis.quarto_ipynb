     },
     "execution_count": 17,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "#| tbl-cap: Regression outputs Spread on Volatility, HC1 robust SE; *** p<.01, ** p<.05, * p<.10\n",
    "reg_rows = []\n",
    "models = {}\n",
    "for s in chosen_stocks:\n",
    "    sub = daily[daily[\"Stock\"] == s]\n",
    "    X = sm.add_constant(sub[\"Daily_Volatility\"].values)\n",
    "    res = sm.OLS(sub[\"Daily_Spread\"].values, X).fit(cov_type=\"HC1\")\n",
    "    models[s] = res\n",
    "    reg_rows.append({\n",
    "        \"Stock\": s,\n",
    "        \"alpha\": res.params[0], \"alpha t\": res.tvalues[0],\n",
    "        \"beta (volatility)\": res.params[1], \"beta t\": res.tvalues[1],\n",
    "        \"beta p-value\": res.pvalues[1],\n",
    "        \"R-squared\": res.rsquared, \"N\": int(res.nobs),\n",
    "    })\n",
    "\n",
    "# --- Compact regression comparison instead of three full summaries ---\n",
    "\n",
    "# 1) Side-by-side comparison table: every stock as a column, every stat as a row.\n",
    "def _star(p):\n",
    "    return \"***\" if p < 0.01 else \"**\" if p < 0.05 else \"*\" if p < 0.10 else \"\"\n",
    "\n",
    "rows = {}\n",
    "for s in chosen_stocks:\n",
    "    res = models[s]\n",
    "    a, b = res.params\n",
    "    se_a, se_b = res.bse\n",
    "    t_a, t_b = res.tvalues\n",
    "    p_a, p_b = res.pvalues\n",
    "    ci_lo, ci_hi = res.conf_int()[1]\n",
    "    rows[s] = {\n",
    "        \"alpha (bps)\":             f\"{a:.3f}\",\n",
    "        \"  std err\":               f\"({se_a:.3f})\",\n",
    "        \"  t-stat\":                f\"{t_a:.2f}\",\n",
    "        \"beta on volatility\":      f\"{b:.3f}{_star(p_b)}\",\n",
    "        \"  std err \":              f\"({se_b:.3f})\",\n",
    "        \"  t-stat \":               f\"{t_b:.2f}\",\n",
    "        \"  95% CI\":                f\"[{ci_lo:.2f}, {ci_hi:.2f}]\",\n",
    "        \"R-squared\":               f\"{res.rsquared:.3f}\",\n",
    "    }\n",
    "comp = pd.DataFrame(rows)\n",
    "comp.index.name = \"Daily_Spread ~ const + Daily_Volatility\"\n",
    "\n",
    "comp"
   ]
  },
  {
   "cell_type": "code",
