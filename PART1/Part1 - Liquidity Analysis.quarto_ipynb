   ],
   "source": [
    "#| fig-cap: \"Daily OHLC Candlesticks (mid-quote). Top to bottom; AstraZeneca, Next, and Burberry.\"\n",
    "fig, axes = plt.subplots(3, 1, figsize=(15, 9))\n",
    "for ax, stock in zip(axes, chosen_stocks):\n",
    "    s = (df.loc[df[\"Stock\"] == stock, [\"Date and time\", \"Midquote_GBP\"]]\n",
    "           .set_index(\"Date and time\").sort_index())\n",
    "    ohlc = s[\"Midquote_GBP\"].resample(\"1D\").ohlc().dropna().reset_index(drop=True)\n",
    "    for x, row in ohlc.iterrows():\n",
    "        up = row[\"close\"] >= row[\"open\"]\n",
    "        colour = \"#2d6c3e\" if up else \"#8B0000\"\n",
    "        ax.plot([x, x], [row[\"low\"], row[\"high\"]], color=colour, linewidth=0.9)\n",
    "        lower  = min(row[\"open\"], row[\"close\"])\n",
    "        height = abs(row[\"close\"] - row[\"open\"]) or (row[\"high\"] - row[\"low\"]) * 0.02\n",
    "        ax.add_patch(Rectangle((x - 0.3, lower), 0.6, height, facecolor=colour, edgecolor=colour))\n",
    "    ax.set_title(f\"{stock} - {STOCK_INFO[stock]['name']}\", loc=\"left\")\n",
    "    ax.set_ylabel(\"Mid-quote (GBP)\")\n",
    "    ax.set_xlim(-1, len(ohlc))\n",
    "axes[-1].set_xlabel(\"Trading day\")\n",
    "fig.suptitle(\"Daily OHLC candlesticks (mid-quote)\", fontweight=\"bold\")\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
