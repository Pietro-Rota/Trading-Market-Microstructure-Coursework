   "source": [
    "#| tbl-cap: Correlation between variables of interest and volatility\n",
    "rows = []\n",
    "for s in chosen_stocks:\n",
    "    sub = daily[daily[\"Stock\"] == s]\n",
    "    for label, col in [(\"Spread vs volatility\", \"Daily_Spread\"),\n",
    "                       (\"Depth vs volatility\",  \"Daily_Depth\")]:\n",
    "        r, p = stats.pearsonr(sub[col], sub[\"Daily_Volatility\"])\n",
    "        rows.append({\"Stock\": s, \"Relationship\": label,\n",
    "                     \"Pearson r\": round(r, 3), \"p-value\": round(p, 4)})\n",
    "pd.DataFrame(rows)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f05eaa9d",
   "metadata": {},
   "source": [
    "Spread and volatility are positively correlated for all three stocks, and depth and volatility are negatively correlated. In words, on more volatile days spreads widen and depth thins out at the same time, so liquidity gets worse exactly when prices are moving most."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "2a65725c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
